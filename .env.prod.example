# Production environment for docker-compose.prod.yml — COPY to .env.prod and fill with REAL values.
# .env.prod is git-ignored and must NEVER be committed (the secret-scan hook blocks real secrets here too).
# All values below are placeholders, not secrets.

# ── Database (the EXISTING shared saude-mandaguari DB; strangler-fig) ─────────────────────────────
# Use host.docker.internal to reach a DB on the host (the compose file maps it on Linux).
DB_URL=jdbc:postgresql://host.docker.internal:5432/saude-mandaguari
DB_USER=<db-username>
DB_PASSWORD=<db-password>

# ── JWT signing key (HS256) ──────────────────────────────────────────────────────────────────────
# MUST be a strong random string >= 32 bytes. ProductionSecurityGuard refuses to start if this looks
# like a dev placeholder (contains "insecure"/"change-me"/"dev-local") or is shorter than 32 bytes.
# Generate one, e.g.:  openssl rand -base64 48
JWT_SECRET=<32+-byte-random-secret>

# ── CORS — comma-separated allowed SPA origins (the frontend's public URL) ────────────────────────
CORS_ALLOWED_ORIGINS=https://receituario.suaprefeitura.gov.br

# ── AES key for the SAU_PRO certificate-password converter (base64, 32 bytes) ─────────────────────
# Generate, e.g.:  openssl rand -base64 32
CERT_ENC_KEY=<base64-32-byte-aes-key>

# ── Optional JVM tuning ──────────────────────────────────────────────────────────────────────────
# JAVA_OPTS=-XX:MaxRAMPercentage=75
